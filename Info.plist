<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sparkle auto-update. The rest of Info.plist is generated by Xcode (GENERATE_INFOPLIST_FILE)
	     and merged on top of these keys. SUPublicEDKey must live here — Sparkle has no delegate
	     override for the public key, by design. -->
	<key>SUFeedURL</key>
	<string>https://raw.githubusercontent.com/Rounds-Org/rounds/main/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>1rEiY0g387CDEZKG4Kq8wzwy1ySXWcH0OGd6mpf2sc8=</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<!-- Amplitude ingestion key, injected at build time from the AMPLITUDE_API_KEY build setting
	     (see tools/notarize.sh + secrets/amplitude.env). Empty in the public repo / unset builds,
	     which disables analytics entirely. Read in AnalyticsService.swift. -->
	<key>AmplitudeAPIKey</key>
	<string>$(AMPLITUDE_API_KEY)</string>
	<!-- Check hourly while running (3600 = Sparkle's minimum), not the 24h default — a Rounds
	     window can stay open for months. SparkleUpdater also re-checks on wake/app-activation. -->
	<key>SUScheduledCheckInterval</key>
	<integer>3600</integer>
</dict>
</plist>
